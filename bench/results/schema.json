{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Cloudflare Auth Hasher Benchmark Record",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "candidate",
      "path",
      "track",
      "algorithm",
      "preset",
      "operation",
      "input",
      "concurrency",
      "successRate",
      "cpuTimeMs",
      "wallTimeMs",
      "startupMs",
      "bundleBytes",
      "errors",
      "scenarioId",
      "samples"
    ],
    "properties": {
      "candidate": {
        "type": "string",
        "enum": ["ts-direct", "ts-rust-wasm", "rust-full", "assemblyscript-probe"]
      },
      "path": {
        "type": "string",
        "enum": ["direct", "binding"]
      },
      "track": {
        "type": "string",
        "enum": ["parity", "deployment"]
      },
      "algorithm": {
        "type": "string",
        "enum": ["argon2id"]
      },
      "preset": {
        "type": "string"
      },
      "operation": {
        "type": "string",
        "enum": ["hash", "verify", "noop"]
      },
      "input": {
        "type": "string"
      },
      "concurrency": {
        "type": "number"
      },
      "successRate": {
        "type": "number"
      },
      "cpuTimeMs": {
        "$ref": "#/$defs/quantiles"
      },
      "wallTimeMs": {
        "$ref": "#/$defs/quantiles"
      },
      "startupMs": {
        "type": ["number", "null"]
      },
      "bundleBytes": {
        "type": "object",
        "required": ["raw", "gzip"],
        "properties": {
          "raw": {
            "type": ["number", "null"]
          },
          "gzip": {
            "type": ["number", "null"]
          }
        }
      },
      "errors": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "scenarioId": {
        "type": "string"
      },
      "samples": {
        "type": "number"
      }
    }
  },
  "$defs": {
    "quantiles": {
      "type": "object",
      "required": ["p50", "p95", "p99"],
      "properties": {
        "p50": {
          "type": ["number", "null"]
        },
        "p95": {
          "type": ["number", "null"]
        },
        "p99": {
          "type": ["number", "null"]
        }
      }
    }
  }
}
