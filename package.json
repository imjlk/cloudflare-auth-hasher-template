{
  "name": "cloudflare-auth-hasher-template",
  "version": "0.1.0",
  "private": true,
  "description": "Reusable Rust-based Argon2id password hasher for Cloudflare Workers service bindings.",
  "scripts": {
    "build": "cargo install -q \"worker-build@^0.7\" && worker-build --release",
    "check": "cargo check --target wasm32-unknown-unknown",
    "deploy": "wrangler deploy",
    "dev": "wrangler dev"
  },
  "devDependencies": {
    "wrangler": "^4.71.0"
  }
}
